{
  "name": "fetch-crawl-mcp",
  "version": "4.1.0",
  "description": "MCP server for fetching, crawling, and analyzing websites",
  "type": "module",
  "bin": {
    "fetch-crawl-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "start:http": "node build/index.js --http",
    "dev": "tsx watch src/index.ts"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cheerio": "^1.0.0",
    "express": "^4.21.0",
    "puppeteer": "^24.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
